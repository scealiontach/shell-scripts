#!/usr/bin/env bash
# Recording stub for docker used by the bats suite.
#
# Contract:
#   * Writes the full argv to $DOCKER_ARGV_LOG (one invocation per line,
#     space-separated). Tests assert against this file.
#   * Looks up the per-subcommand exit code in DOCKER_PULL_RC / DOCKER_TAG_RC /
#     DOCKER_PUSH_RC. Each defaults to 0; set to a non-zero value to simulate
#     a failure of that particular docker subcommand.
#   * Other subcommands (inspect, login, etc.) exit 0 and emit nothing.
echo "$@" >>"${DOCKER_ARGV_LOG:-/dev/null}"
case "${1:-}" in
  pull) exit "${DOCKER_PULL_RC:-0}" ;;
  tag) exit "${DOCKER_TAG_RC:-0}" ;;
  push) exit "${DOCKER_PUSH_RC:-0}" ;;
  *) exit 0 ;;
esac
