#!/usr/bin/env bash

alias ku='kubectl config use-context'
alias kc='kubectl config set-context --current'
alias kn='kubectl config set-context --current --namespace'
alias kd='kubectl describe'
alias kl='kubectl logs'
alias k='kubectl'
alias kls='kubectl config get-contexts -o name'
alias klc='kubectl config get-clusters| grep -v NAME'
alias klu='kubectl config get-users| grep -v NAME'
#shellcheck disable=SC2142
alias kln='k get ns -o name |awk -F/ "{print \$2}"'
alias kg='k get'
alias ke='k exec'

function ks {
  local pod=$1
  local -a cmd=(kubectl exec -it "$pod")
  if [ -n "$2" ]; then
    local container=$2
    cmd+=(-c "$container")
  fi
  cmd+=(-- bash)
  "${cmd[@]}"
}

function kss {
  local pod=$1
  local -a cmd=(kubectl exec -it "$pod")
  if [ -n "$2" ]; then
    local container=$2
    cmd+=(-c "$container")
  fi
  cmd+=(-- sh)
  "${cmd[@]}"
}

function update_eksctl {
  # Pinned version: bump manually after reviewing release notes.
  # Override at runtime: EKSCTL_VERSION=v0.210.0 update_eksctl
  # Checksum URL: https://github.com/weaveworks/eksctl/releases/download/VERSION/eksctl_checksums.txt
  local eksctl_version=${EKSCTL_VERSION:-v0.207.0}
  local arch
  case "$(uname -m)" in
    x86_64) arch=amd64 ;;
    aarch64 | arm64) arch=arm64 ;;
    *)
      echo "update_eksctl: unsupported architecture '$(uname -m)'" >&2
      return 1
      ;;
  esac
  local os
  os=$(uname -s)
  local tmpdir
  tmpdir=$(mktemp -d)
  trap 'rm -rf "$tmpdir"' RETURN
  local tarball="eksctl_${os}_${arch}.tar.gz"
  local base_url="https://github.com/weaveworks/eksctl/releases/download/${eksctl_version}"
  if ! curl -fsSL -o "$tmpdir/${tarball}" "${base_url}/${tarball}"; then
    echo "update_eksctl: download failed" >&2
    return 1
  fi
  if ! curl -fsSL -o "$tmpdir/eksctl_checksums.txt" "${base_url}/eksctl_checksums.txt"; then
    echo "update_eksctl: checksum file download failed" >&2
    return 1
  fi
  # Verify SHA-256: extract the hash for our tarball and check against the download.
  local expected_hash
  expected_hash=$(grep "[[:space:]]${tarball}$" "$tmpdir/eksctl_checksums.txt" | awk '{print $1}')
  if [ -z "$expected_hash" ]; then
    echo "update_eksctl: ${tarball} not found in checksums file" >&2
    return 1
  fi
  if ! echo "${expected_hash}  $tmpdir/${tarball}" | sha256sum --check --status; then
    echo "update_eksctl: SHA-256 verification failed" >&2
    return 1
  fi
  tar xz -C "$tmpdir" -f "$tmpdir/${tarball}"
  mkdir -p "$HOME/.local/bin"
  mv "$tmpdir/eksctl" "$HOME/.local/bin/"
}

function update_helm {
  # Pinned version: bump manually after reviewing release notes.
  # Avoids piping a network-fetched master-branch script straight to bash.
  local helm_version=v3.16.4
  local arch
  case "$(uname -m)" in
    x86_64) arch=amd64 ;;
    aarch64 | arm64) arch=arm64 ;;
    *)
      echo "update_helm: unsupported architecture '$(uname -m)'" >&2
      return 1
      ;;
  esac
  local os
  os=$(uname -s | tr '[:upper:]' '[:lower:]')
  local tmpdir
  tmpdir=$(mktemp -d)
  trap 'rm -rf "$tmpdir"' RETURN
  if ! curl -fsSL -o "$tmpdir/helm.tgz" \
    "https://get.helm.sh/helm-${helm_version}-${os}-${arch}.tar.gz"; then
    echo "update_helm: download failed" >&2
    return 1
  fi
  tar xz -C "$tmpdir" -f "$tmpdir/helm.tgz"
  mkdir -p "$HOME/.local/bin"
  mv "$tmpdir/${os}-${arch}/helm" "$HOME/.local/bin/helm"
}

function update_pip3_packages {
  local package=()
  package+=(awscli)
  package+=(pre-commit)
  package+=(commitizen)
  package+=(powerline-status)
  package+=(powerline-gitstatus)
  package+=(powerline-kubernetes)
  package+=(docker-compose)
  for pkg in "${package[@]}"; do
    pip3 install "$pkg" --upgrade --upgrade-strategy only-if-needed --user
  done
}

function update_packages {
  if command -v yum; then
    sudo yum update -y --nogpgcheck
  elif command -v apt-get; then
    sudo apt-get update -q -y
    sudo apt-get upgrade -y -q
    sudo apt-get autoremove -y -q
  elif command -v nixos-rebuild; then
    sudo nix-channel --update
    sudo nixos-rebuild switch --upgrade
  fi
}

function update_kubectl {
  # Version is queried live from dl.k8s.io/release/stable.txt.
  # Override at runtime: KUBECTL_VERSION=v1.32.0 update_kubectl
  # Checksum URL: https://dl.k8s.io/release/VERSION/bin/OS/ARCH/kubectl.sha256
  local version=${KUBECTL_VERSION:-}
  if [ -z "$version" ]; then
    version=$(curl -fsSL https://dl.k8s.io/release/stable.txt)
  fi
  local arch
  case "$(uname -m)" in
    x86_64) arch=amd64 ;;
    aarch64 | arm64) arch=arm64 ;;
    *)
      echo "update_kubectl: unsupported architecture '$(uname -m)'" >&2
      return 1
      ;;
  esac
  local os
  os=$(uname -s | tr '[:upper:]' '[:lower:]')
  local tmpdir
  tmpdir=$(mktemp -d)
  trap 'rm -rf "$tmpdir"' RETURN
  local base_url="https://dl.k8s.io/release/${version}/bin/${os}/${arch}"
  if ! curl -fsSL -o "$tmpdir/kubectl" "${base_url}/kubectl"; then
    echo "update_kubectl: download failed" >&2
    return 1
  fi
  if ! curl -fsSL -o "$tmpdir/kubectl.sha256" "${base_url}/kubectl.sha256"; then
    echo "update_kubectl: checksum file download failed" >&2
    return 1
  fi
  # kubectl.sha256 contains only the hash (no filename); construct the check input.
  local expected_hash
  expected_hash=$(cat "$tmpdir/kubectl.sha256")
  if ! echo "${expected_hash}  $tmpdir/kubectl" | sha256sum --check --status; then
    echo "update_kubectl: SHA-256 verification failed" >&2
    return 1
  fi
  install -m 0755 "$tmpdir/kubectl" "$HOME/.local/bin/kubectl"
}

function update_vundle {
  git clone https://github.com/VundleVim/Vundle.vim.git ~/.vim/bundle/Vundle.vim
}

function ua {
  update_packages
  update_eksctl
  update_helm
  update_kubectl
  update_pip3_packages
  update_vundle
}

function get_latest_btp_branch {
  for d in *; do
    echo "Check $d"
    if [ -d "$d/.git" ]; then
      cd "$d" || continue
      # tail -n 1 to pick only the latest sorted branch; bare 'tail' defaults
      # to -n 10 and would check out 10 branches sequentially.
      for b in $(git branch -la | grep origin/btp-releases | sort | tail -n 1); do
        branch=${b##remotes/origin/}
        echo "Set $d to branch $branch"
        git checkout "$branch" "$@"
      done
      cd - || exit 1
    fi
  done
}
