#!/usr/bin/env bash

alias ku='kubectl config use-context'
alias kc='kubectl config set-context --current'
alias kn='kubectl config set-context --current --namespace'
alias kd='kubectl describe'
alias kl='kubectl logs'
alias k='kubectl'
alias kls='kubectl config get-contexts -o name'
alias klc='kubectl config get-clusters| grep -v NAME'
alias klu='kubectl config get-users| grep -v NAME'
#shellcheck disable=SC2142
alias kln='k get ns -o name |awk -F/ "{print \$2}"'
alias kg='k get'
alias ke='k exec'

function ks {
  local pod=$1
  local -a cmd=(kubectl exec -it "$pod")
  if [ -n "$2" ]; then
    local container=$2
    cmd+=(-c "$container")
  fi
  cmd+=(-- bash)
  "${cmd[@]}"
}

function kss {
  local pod=$1
  local -a cmd=(kubectl exec -it "$pod")
  if [ -n "$2" ]; then
    local container=$2
    cmd+=(-c "$container")
  fi
  cmd+=(-- sh)
  "${cmd[@]}"
}

function update_eksctl {
  local arch
  case "$(uname -m)" in
    x86_64) arch=amd64 ;;
    aarch64 | arm64) arch=arm64 ;;
    *)
      echo "update_eksctl: unsupported architecture '$(uname -m)'" >&2
      return 1
      ;;
  esac
  curl --silent --location \
    "https://github.com/weaveworks/eksctl/releases/latest/download/eksctl_$(uname -s)_${arch}.tar.gz" |
    tar xz -C /tmp
  mkdir -p "$HOME/.local/bin"
  mv /tmp/eksctl "$HOME/.local/bin"
}

function update_helm {
  # Pinned version: bump manually after reviewing release notes.
  # Avoids piping a network-fetched master-branch script straight to bash.
  local helm_version=v3.16.4
  local arch
  case "$(uname -m)" in
    x86_64) arch=amd64 ;;
    aarch64 | arm64) arch=arm64 ;;
    *)
      echo "update_helm: unsupported architecture '$(uname -m)'" >&2
      return 1
      ;;
  esac
  local os
  os=$(uname -s | tr '[:upper:]' '[:lower:]')
  local tmpdir
  tmpdir=$(mktemp -d)
  trap 'rm -rf "$tmpdir"' RETURN
  if ! curl -fsSL -o "$tmpdir/helm.tgz" \
    "https://get.helm.sh/helm-${helm_version}-${os}-${arch}.tar.gz"; then
    echo "update_helm: download failed" >&2
    return 1
  fi
  tar xz -C "$tmpdir" -f "$tmpdir/helm.tgz"
  mkdir -p "$HOME/.local/bin"
  mv "$tmpdir/${os}-${arch}/helm" "$HOME/.local/bin/helm"
}

function update_pip3_packages {
  local package=()
  package+=(awscli)
  package+=(pre-commit)
  package+=(commitizen)
  package+=(powerline-status)
  package+=(powerline-gitstatus)
  package+=(powerline-kubernetes)
  package+=(docker-compose)
  for pkg in "${package[@]}"; do
    pip3 install "$pkg" --upgrade --upgrade-strategy only-if-needed --user
  done
}

function update_packages {
  if command -v yum; then
    sudo yum update -y --nogpgcheck
  elif command -v apt-get; then
    sudo apt-get update -q -y
    sudo apt-get upgrade -y -q
    sudo apt-get autoremove -y -q
  elif command -v nixos-rebuild; then
    sudo nix-channel --update
    sudo nixos-rebuild switch --upgrade
  fi
}

function update_kubectl {
  local latest
  latest=$(curl -s \
    https://storage.googleapis.com/kubernetes-release/release/stable.txt)
  tmpdir=$(mktemp -d)
  cd "${tmpdir}" || return 1
  curl -LO \
  "https://storage.googleapis.com/kubernetes-release/release/${latest}/bin/linux/amd64/kubectl"
  chmod +x kubectl
  mv ./kubectl "$HOME/.local/bin"
  cd - || return 1
}

function update_vundle {
  git clone https://github.com/VundleVim/Vundle.vim.git ~/.vim/bundle/Vundle.vim
}

function ua {
  update_packages
  update_eksctl
  update_helm
  update_kubectl
  update_pip3_packages
  update_vundle
}

function get_latest_btp_branch {
  for d in *; do
    echo "Check $d"
    if [ -d "$d/.git" ]; then
      cd "$d" || continue
      # tail -n 1 to pick only the latest sorted branch; bare 'tail' defaults
      # to -n 10 and would check out 10 branches sequentially.
      for b in $(git branch -la | grep origin/btp-releases | sort | tail -n 1); do
        branch=${b##remotes/origin/}
        echo "Set $d to branch $branch"
        git checkout "$branch" "$@"
      done
      cd - || exit 1
    fi
  done
}
