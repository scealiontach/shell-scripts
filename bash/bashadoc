if [ -z "${1:-}" ]; then
  echo "bashadoc: usage: bashadoc <library.sh>" >&2
  exit 1
fi
if [ ! -f "$1" ]; then
  echo "bashadoc: not a regular file: $1" >&2
  exit 1
fi
case "$1" in
  *.sh) ;;
  *)
    echo "bashadoc: expected a .sh file: $1" >&2
    exit 1
    ;;
esac

# shellcheck disable=SC1090
source "$1"

# SUR-2829: anchor the @package extraction so it matches only literal
# `@package <name>` directives. The previous `grep "@package"` also
# matched `function @package() {` in doc.sh, producing `{` as the
# "package name". Anchoring on a leading-whitespace `@package ` and
# taking field 2 guarantees we read the directive's argument.
package=$(awk '/^[[:space:]]*@package[[:space:]]/{print $2}' "$1" | tail -1)
funcs=$(declare -F | awk '{print $NF}' | grep -v "@")
if [ -n "$package" ]; then
  title="\`$package\`"
  funcs=$(echo "$funcs" | grep "^$package::")
else
  title="$1"
  funcs=$(echo "$funcs" | grep -v "::")
fi
echo "# $title package"
for func in $funcs; do
  # Use [[:space:]] (POSIX) instead of \s — BSD grep does not treat \s as whitespace.
  docs=$(declare -f "$func" | grep '^[[:space:]]*@doc ' | sed -e 's/^[[:space:]]*@doc[[:space:]]*//')
  args=$(declare -f "$func" | grep '^[[:space:]]*@arg ' | sed -e 's/^[[:space:]]*@arg[[:space:]]*/- /')
  echo
  echo "## \`$func\`"
  echo
  ([ -n "$docs" ] && echo "$docs" | tr ";" " " | sed -e 's/\ $//') || true
  ([ -n "$args" ] && echo && echo "### Arguments" && echo && echo "$args" |
    tr ";" " ") || true
done
