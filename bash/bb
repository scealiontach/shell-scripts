# shellcheck source=includer.sh
source "$(dirname "${BASH_SOURCE[0]}")/includer.sh"

@include commands
@include error
@include options

options::standard
options::add -o c -d "Config file for BB rest api" -a -m -e CONFIG
options::parse "$@"

shift $((OPTIND - 1))
# shellcheck disable=SC2154 # CONFIG exported by options::add -e
if [ -z "$CONFIG" ] || [[ ! "$CONFIG" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  error::exit "Invalid -c config name: '$CONFIG' (allowed: [a-zA-Z0-9_-]+)"
fi
if [ -r "$HOME/.${CONFIG}-config" ]; then
  # shellcheck source=/dev/null
  source "$HOME/.${CONFIG}-config"
else
  error::exit "Specified config($CONFIG) was not found"
fi

function ::curl() {
  $(commands::use curl) "$@"
}

# Local jq shim so a missing jq binary fails loudly with the standard
# "not on the PATH" commands::use error instead of silently emitting
# empty output downstream (SUR-1927).
function ::jq() {
  local jq_path
  jq_path=$(commands::use jq) || return 1
  "$jq_path" "$@"
}

function bb_api_call() {
  local method=$1
  local url=$2
  shift 2
  ::curl -s -X "$method" -u "$BB_USER:$BB_PAT" \
    "$BB_HOST/rest/api/latest/$url" "$@" | ::jq
}

function pr-data() {
  local slug="$1"
  local project repo_name
  project=$(echo "$slug" | awk -F/ '{print $1}')
  repo_name=$(echo "$slug" | awk -F/ '{print $2}')
  bb_api_call GET "projects/$project/repos/$repo_name/pull-requests?state=open&limit=100"
}

function pr-count() {
  local slug=$1
  pr-data "$slug" | ::jq -r '.size'
}

function pr-list() {
  local slug=$1
  pr-data "$slug" | ::jq -r '.values[].links.self[].href'
}

case "${1:-}" in
  pr-data | pr-count | pr-list) "$@" ;;
  '') error::exit "Subcommand required (one of: pr-data, pr-count, pr-list)" ;;
  *) error::exit "Unknown subcommand: $1" ;;
esac
