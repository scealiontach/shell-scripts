# shellcheck source=includer.sh
source "$(dirname "${BASH_SOURCE[0]}")/includer.sh"

@include commands
@include k8s
@include log
@include options

options::standard
options::description "Migrate the keys from one validator to another."
options::add -o f -d "node to migrate from" -a -m -e FROM_NODE
options::add -o t -d "node to migrate to" -a -m -e TRGT_NODE
options::add -o l -d "label of the sawtooth" -a -m -e LABEL
options::parse "$@"

function getPodsForLabel() {
  local label=${1:?}
  k8s::ctl get pods -l "$label" -o name | awk -F/ '{print $2}'
}

function getNodeForPod() {
  local pod=${1:?}
  k8s::ctl get "pod/${pod}" -o json | $(commands::use jq) -r '.spec.nodeName'
}

# Populate the two associative-array name-references with the
# node↔pod mapping for the given label. The maps are passed by
# nameref so callers (notably `main`) own their lifetime as locals
# rather than this script's globals — see SUR-1872.
function mapPods() {
  local _label=${1:?}
  local -n _node2pod=${2:?}
  local -n _pod2node=${3:?}
  log::info "mapping pods to nodes for label $_label"
  local p node
  for p in $(getPodsForLabel "${_label:?}"); do
    node=$(getNodeForPod "${p}")
    # shellcheck disable=SC2004 # associative-array index, not arithmetic
    _node2pod[$node]=$p
    # shellcheck disable=SC2004 # associative-array index, not arithmetic
    _pod2node[$p]=$node
  done
}

TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT INT TERM
log::info "using temporary directory $TEMP_DIR"
function getKeys() {
  local pod=${1:?}
  log::info "fetching keys from $pod"
  mkdir -p "$TEMP_DIR/$pod"
  k8s::ctl cp "$pod:etc/sawtooth/keys" "$TEMP_DIR/$pod" -c validator
}

function pushKeys() {
  local from_pod=${1:?}
  local to_pod=${2:?}
  log::info "push keys to $to_pod"
  if [ -d "$TEMP_DIR/$from_pod" ]; then
    k8s::ctl cp "$TEMP_DIR/$from_pod/validator.priv" "$to_pod:etc/sawtooth/keys/" \
      -c validator &&
      k8s::ctl cp "$TEMP_DIR/$from_pod/validator.pub" "$to_pod:etc/sawtooth/keys/" \
        -c validator
    return $?
  else
    log::error "Source keys don't exist at dir $TEMP_DIR/$from_pod"
    return 1
  fi
}

function unlabelNode() {
  local node=${1:?}
  local label=${2:?}
  log::info "Removing label $label from node $node"
  local neg_label
  neg_label="${label//=*/}-"
  k8s::ctl label node "$node" "$neg_label"
}

function labelNode() {
  local node=${1:?}
  local label=${2:?}
  log::info "Adding label $label to node $node"
  k8s::ctl label node "$node" "$label"
}

# Maximum seconds to wait for a pod to terminate before giving up. Override
# via the WAIT_FOR_POD_TERMINATION_TIMEOUT environment variable.
WAIT_FOR_POD_TERMINATION_TIMEOUT=${WAIT_FOR_POD_TERMINATION_TIMEOUT:-600}

function waitForPodTermination() {
  local pod=${1:?}
  local timeout=${2:-$WAIT_FOR_POD_TERMINATION_TIMEOUT}
  local deadline=$(($(date +%s) + timeout))
  log::info "Waiting for pod $pod to terminate (timeout ${timeout}s)"
  while k8s::ctl get pod "$pod" -o name >/dev/null 2>&1; do
    if [ "$(date +%s)" -ge "$deadline" ]; then
      log::error "Timed out after ${timeout}s waiting for pod $pod to terminate"
      return 1
    fi
    sleep 5
    log::info "Waiting for pod $pod to terminate"
  done
}

function main() {
  set -euo pipefail
  local -A node2pod=()
  # mapPods writes to pod2node via nameref but the script does not read
  # it; kept as part of mapPods's contract for diagnostic / future use.
  # shellcheck disable=SC2034
  local -A pod2node=()
  # shellcheck disable=SC2153
  mapPods "$LABEL" node2pod pod2node
  local from_pod=${node2pod[$FROM_NODE]}
  local to_pod=${node2pod[$TRGT_NODE]}

  getKeys "$from_pod"
  getKeys "$to_pod"
  pushKeys "$from_pod" "$to_pod"
  unlabelNode "$FROM_NODE" "$LABEL"
  waitForPodTermination "$from_pod"
  unlabelNode "$TRGT_NODE" "$LABEL"
  waitForPodTermination "$to_pod"
  labelNode "$TRGT_NODE" "$LABEL"

}

main
