# shellcheck source=includer.sh
source "$(dirname "${BASH_SOURCE[0]}")/includer.sh"

@include options
@include git
@include log
@include dirs

options::standard
options::description "Add a new tag to the repository based on semver and\
 conventional commits. Annotated tags are GPG-signed (git tag -s), which\
 requires a configured signing key (user.signingkey + gpg-agent or\
 equivalent); pass -U to write an unsigned annotated tag instead."
options::add -o t -d "target directory to examine and update" -a -m \
  -e TARGET_DIR
options::add -o p -d "Patch tag" \
  -x PATCH_TAG
options::add -o b -d "proceed to bump minor version if breaking changes are found" \
  -x ALLOW_BREAKING
options::add -o c -d "generate and commit change before tagging" \
  -x GENERATE_CHANGELOG
options::add -o U -d "skip GPG signing of the annotated tag" \
  -x NO_SIGN_TAG
options::parse "$@"

pushd "$TARGET_DIR" >/dev/null || exit 1

ANNOTATE_TAG=true
if ! LATEST_TAG=$(git::cmd describe --tags --match 'v*' --abbrev=0 2>/dev/null); then
  log::notice "No prior v* tag found in $TARGET_DIR; defaulting to v0.1.0"
  LATEST_TAG="v0.1.0"
  ANNOTATE_TAG=false
  RANGE="HEAD"
else
  RANGE="$LATEST_TAG..HEAD"
fi

if ! LATEST_ANNOTATED_TAG=$(git::cmd describe --match 'v*' --abbrev=0 2>/dev/null); then
  log::notice "No prior tag was annotated"
  ANNOTATE_TAG=false
else
  if [ "$LATEST_TAG" != "$LATEST_ANNOTATED_TAG" ] || [ -z "$LATEST_ANNOTATED_TAG" ]; then
    ANNOTATE_TAG=false
  fi
fi

LATEST_VERSION=$(echo "$LATEST_TAG" | cut -c2-)

# Conventional Commits flags a breaking change in two distinct ways:
#   1. A `!` before the colon in the subject form: feat!:, fix(scope)!:, etc.
#   2. A `BREAKING CHANGE:` or `BREAKING-CHANGE:` footer in the body.
# Format includes both subject (%s) and body (%b) so both forms are visible.
BREAKING_CHANGES=$(git::cmd log "$RANGE" --pretty=format:'%s%n%b' |
  grep -cE '(^[a-zA-Z]+(\([^)]+\))?!:|BREAKING[ -]CHANGE:)')
CHANGES=$(git::cmd log "$RANGE" --pretty=format:'%H' | grep -c .)

log::notice "Since $LATEST_VERSION $CHANGES changes  $BREAKING_CHANGES breaks"

skip="true"
if [ "$BREAKING_CHANGES" -gt 0 ]; then
  if [ "${ALLOW_BREAKING}" = "true" ]; then
    TAG=$("$(dirs::of)/semver" bump minor "$LATEST_VERSION")
    skip="false"
  else
    log::warn "Minor version changes due to breaking changes must be explicity allowed!"
    exit 1
  fi
elif [ "$CHANGES" -gt 0 ]; then
  # if we can't annotate tag then we must do a prerel bump
  if [ "${ANNOTATE_TAG}" = "false" ]; then
    PREREL=$("$(dirs::of)/semver" get prerel "$LATEST_VERSION")
    # Lightweight-tag path: numeric prerel segments only. Non-numeric values
    # break arithmetic and the -$PREREL substitution can corrupt the tag
    # (SUR-2457). Empty prerel starts the pN sequence at 1.
    if [[ -z "$PREREL" ]]; then
      NEXT_PREREL=1
    elif [[ "$PREREL" =~ ^[0-9]+$ ]]; then
      NEXT_PREREL=$((10#$PREREL + 1))
    else
      log::notice "Non-numeric prerel '${PREREL}' in ${LATEST_VERSION}; resetting lightweight prerel counter to 1"
      NEXT_PREREL=1
    fi
    TAG=$("$(dirs::of)/semver" bump prerel "$NEXT_PREREL" "$LATEST_VERSION")
    TAG=${TAG/"-${NEXT_PREREL}"/"p${NEXT_PREREL}"}
  else
    TAG=$("$(dirs::of)/semver" bump patch "$LATEST_VERSION")
  fi
  skip="false"
else
  log::notice "No changes since $LATEST_VERSION"
  TAG="$LATEST_VERSION"
  skip="true"
fi

TAG="v${TAG}"

if [ "$skip" = "false" ]; then
  log::notice "Will tag as $TAG"
  if [ "$ANNOTATE_TAG" = "false" ]; then
    log::notice "No changelog updates for prerel builds"
    git::cmd tag "$TAG"
  else
    if [ "$GENERATE_CHANGELOG" = "true" ]; then
      if [ -r "CHANGELOG.md" ]; then
        "$(dirs::of)"/changelog -l | sed -e "s/Unreleased/$TAG/" >CHANGELOG.md
        git add CHANGELOG.md
        # CI-only bypass: pre-commit hooks fail in non-interactive release contexts
        # (markdownlint may flag mechanically regenerated CHANGELOG.md; the hook
        # runner cannot reach the network for pre-commit binary installs in CI).
        # The source commits that triggered this release already passed pre-commit
        # on their own branches. This is a documented exception to the
        # "never skip hooks" rule — see the "Hook bypass exceptions" section in
        # AGENTS.md. (SUR-1879)
        git commit --no-verify -m "ci: Update CHANGELOG releasing $TAG" CHANGELOG.md
      else
        log::notice "No prior changelog found. Will not generate a new one."
      fi
    fi
    if [ "$NO_SIGN_TAG" = "true" ]; then
      git::cmd tag -a "$TAG" -m "Auto Tagging $TAG"
    else
      git::cmd tag -a -s "$TAG" -m "Auto Tagging $TAG"
    fi
  fi
fi
popd >/dev/null || exit 1
