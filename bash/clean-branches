# shellcheck source=includer.sh
source "$(dirname "${BASH_SOURCE[0]}")/includer.sh"

@include error
@include exec
@include git
@include log
@include options

options::standard
options::set_description "Cleans the target directory of branches which have \
  lost their remote counterparts. With -T, also deletes local and origin tags \
  matching the build/* prefix (CI artifact tags); this destructive cleanup is \
  off by default. Use -n for a dry run that prints intended deletions without \
  touching anything."
options::add -o d -d "target directory" -a -e TARGET_DIR
options::add -o T -d "also clean build/* tags from local and origin (opt-in)" -x CLEAN_BUILD_TAGS
options::add -o n -d "dry run: print intended deletions without executing" -x DRY_RUN
options::parse_available "$@"

# globals
TARGET_DIR="${TARGET_DIR:-$(pwd)}"
CLEAN_BUILD_TAGS=${CLEAN_BUILD_TAGS:-false}
DRY_RUN=${DRY_RUN:-false}

if [ ! -d "$TARGET_DIR/.git" ]; then
  error::exit "$TARGET_DIR is not the root of a git repository"
fi

cd "$TARGET_DIR" || error::exit "Failed to cd to $TARGET_DIR, check permissions"

log::info "Fetching for repository $TARGET_DIR"
exec::capture git::cmd fetch -p

# Single loop driven by `git for-each-ref` (requires git >= 2.7 for the
# `%(upstream:track)` format, which produces `[gone]` when the upstream
# has been pruned). The previous implementation ran two near-identical
# loops over `git branch -vv`; the regex `\[.*]` was a glob class, not a
# literal match, and the iterator name and log message diverged.
function delete_branch() {
  local branch=$1
  local reason=$2
  if [ "$DRY_RUN" = "true" ]; then
    log::info "would delete branch $branch ($reason)"
  else
    log::info "Deleting branch $branch ($reason)"
    exec::capture git::cmd branch -D "$branch"
  fi
}

current_branch=$(git::cmd rev-parse --abbrev-ref HEAD 2>/dev/null || true)
log::info "Checking for branches to clean (current: ${current_branch:-<none>})"
while IFS=$'\t' read -r branch upstream track; do
  [ -z "$branch" ] && continue
  # Never delete the branch we are standing on.
  if [ "$branch" = "$current_branch" ]; then
    continue
  fi
  if [ -z "$upstream" ]; then
    delete_branch "$branch" "no remote"
  elif [[ "$track" == *"gone"* ]]; then
    delete_branch "$branch" "remote gone"
  fi
done < <(git::cmd for-each-ref \
  --format='%(refname:short)%09%(upstream:short)%09%(upstream:track)' \
  refs/heads/)

if [ "$CLEAN_BUILD_TAGS" = "true" ]; then
  log::info "Checking for old build/* tags (opt-in via -T)"
  for tag in $(git::cmd tag -l 'build/*'); do
    if [ "$DRY_RUN" = "true" ]; then
      log::info "would delete tag $tag (local + origin)"
    else
      log::info "Deleting tag $tag"
      exec::capture git::cmd push --delete origin "$tag"
      exec::capture git::cmd tag -d "$tag"
    fi
  done
else
  if [ -n "$(git::cmd tag -l 'build/*')" ]; then
    log::info "build/* tags present; pass -T to delete them (skipped)"
  fi
fi
